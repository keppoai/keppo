{
  "name": "keppo",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "planner": "tsx scripts/ralph-planner.ts",
    "ralph-planner": "tsx scripts/ralph-planner.ts",
    "build": "pnpm run build:web",
    "build:web": "pnpm run build:workspace-exports && pnpm --filter @keppo/web build",
    "build:web:vercel": "./scripts/build-web-vercel.sh",
    "free-dev-ports": "node ./scripts/free-dev-ports.mjs",
    "dev": "node ./scripts/dev.mjs",
    "dev:all": "pnpm run dev:web",
    "dev:web": "node ./scripts/wait-for-local-convex-env.mjs && ./scripts/dotenvx-run.sh pnpm --filter @keppo/web dev",
    "dev:izzy": "pnpm --filter @keppo/izzy dev",
    "build:workspace-exports": "pnpm --filter @keppo/shared build && pnpm --filter @keppo/cloud build",
    "vercel-refresh": "./scripts/vercel-refresh.sh",
    "convex:dev": "./scripts/dotenvx-run.sh ./scripts/convex-dev.sh",
    "convex:init": "./scripts/dotenvx-run.sh ./scripts/convex-init.sh",
    "convex:push:local": "./scripts/dotenvx-run.sh ./scripts/convex-push-local.sh",
    "convex:reset": "./scripts/dotenvx-run.sh ./scripts/convex-reset.sh",
    "test:e2e:convex": "./scripts/dotenvx-run.sh ./scripts/e2e-convex.sh",
    "test:e2e:base": "./scripts/dotenvx-run.sh ./scripts/e2e-base.sh",
    "test:convex": "vitest run --config tests/convex/vitest.config.ts",
    "e2e:prepare": "./scripts/dotenvx-run.sh pnpm exec node scripts/e2e-prepare.mjs --build",
    "test:e2e": "E2E_WORKERS=1 pnpm run test:e2e:base && pnpm run test:e2e:noise:check",
    "test:e2e:warm": "KEPPO_E2E_RUNTIME_MODE=prebuilt pnpm run test:e2e:base",
    "test:e2e:dev": "KEPPO_E2E_RUNTIME_MODE=dev pnpm run test:e2e:base",
    "test:e2e:timed": "pnpm exec node scripts/measure-e2e-runtime.mjs",
    "test:e2e:watch": "pnpm run test:e2e:base -- --ui",
    "test:e2e:update": "KEPPO_E2E_ALLOW_SNAPSHOT_UPDATE=1 pnpm run test:e2e:base -- --update-snapshots",
    "test:e2e:headed": "pnpm run test:e2e:base -- --headed",
    "test:e2e:providers": "./scripts/e2e-providers.sh",
    "test:e2e:smoke": "E2E_WORKERS=1 pnpm run test:e2e:base -- tests/e2e/specs/providers/provider-action-matrix.spec.ts tests/e2e/specs/auth/login.spec.ts tests/e2e/specs/auth/signout.spec.ts tests/e2e/specs/integrations/connect-google.spec.ts tests/e2e/specs/actions/pending-to-approved.spec.ts tests/e2e/specs/actions/pending-to-rejected.spec.ts tests/e2e/specs/actions/queue-cron-runtime.spec.ts tests/e2e/specs/workspaces/create-and-switch.spec.ts",
    "test:e2e:ci": "E2E_WORKERS=1 pnpm run test:e2e",
    "test:e2e:ci:timed": "E2E_WORKERS=1 ./scripts/e2e-ci-timed.sh",
    "test:e2e:ci:pr": "pnpm run test:e2e:ci",
    "test:e2e:ci:pr:timed": "pnpm run test:e2e:ci:timed",
    "test:e2e:ci:main": "pnpm run test:e2e:ci",
    "test:e2e:ci:main:timed": "pnpm run test:e2e:ci:timed",
    "test:e2e:authoring:check": "pnpm exec node scripts/check-e2e-authoring.mjs",
    "test:e2e:budget:check": "pnpm exec node scripts/check-e2e-time-budget.mjs",
    "test:e2e:meta": "pnpm exec node scripts/run-e2e-meta-checks.mjs",
    "test:e2e:noise:check": "pnpm exec node scripts/check-e2e-log-noise.mjs",
    "test:web": "pnpm --filter @keppo/web test",
    "test:izzy": "pnpm --filter @keppo/izzy test",
    "test:local-convex": "./scripts/dotenvx-run.sh ./scripts/test-local-convex.sh",
    "test:non-e2e:authoring": "pnpm exec node scripts/check-non-e2e-test-authoring.mjs",
    "test:shared": "pnpm --filter @keppo/shared test",
    "test:non-e2e": "run-s test:non-e2e:authoring test:web test:convex test:local-convex test:shared",
    "test:non-e2e:ci": "run-s test:non-e2e:authoring test:web test:convex test:shared",
    "test:layer3": "pnpm run test:e2e:base -- tests/e2e/specs/providers/provider-action-matrix.spec.ts",
    "test:layer4": "pnpm --filter @keppo/shared test -- connectors.contract.test.ts",
    "test:layer7": "pnpm --filter @keppo/shared test -- provider-write-utils.test.ts",
    "test:conformance": "pnpm --filter @keppo/shared test -- connectors.conformance",
    "ralph": "pnpm exec tsx ./scripts/ralph.ts",
    "ralph-loop": "pnpm exec tsx ./scripts/ralph-loop.ts",
    "ralph-mc": "pnpm exec tsx ./scripts/ralph-mission-control.ts",
    "ralph-update": "pnpm exec tsx ./scripts/ralph-update.ts",
    "check": "pnpm exec tsx ./scripts/check-all.ts",
    "check:all": "pnpm exec tsx ./scripts/check-all.ts",
    "check:same-site-auth-cookie-calls": "pnpm exec node ./scripts/check-same-site-auth-cookie-calls.mjs",
    "check:unused-direct-deps": "pnpm exec node ./scripts/check-unused-direct-deps.mjs",
    "check:barrels": "pnpm exec tsx ./scripts/check-barrel-boundaries.ts",
    "check:providers": "pnpm exec tsx ./scripts/check-all.ts --suite provider-registry-snapshot --suite provider-docs --suite provider-guardrails --suite provider-module-globals",
    "check:security": "pnpm exec tsx ./scripts/check-all.ts --suite security-invariants --suite convex-env-manifest --suite security-regressions --suite same-site-auth-cookie-calls --suite launch-security-defaults --suite oss-artifacts --suite type-safety-debt",
    "check:convex-env-manifest": "pnpm exec node scripts/check-convex-env-manifest.mjs",
    "env:check": "./scripts/dotenvx-run.sh pnpm exec tsx ./scripts/check-env.ts",
    "check:provider-guardrails": "pnpm exec tsx ./scripts/check-provider-guardrails.ts",
    "check:sdk-type-compat": "pnpm exec tsx ./scripts/check-sdk-type-compat.ts",
    "check:provider-registry-snapshot": "pnpm exec tsx ./scripts/check-provider-registry-snapshot.ts",
    "check:provider-docs": "pnpm exec tsx ./scripts/check-provider-docs.ts",
    "validate:provider-manifest": "pnpm exec tsx ./scripts/validate-provider-manifest.ts",
    "check:provider-metrics-alerts": "pnpm exec tsx ./scripts/check-provider-metrics-alerts.ts",
    "check:automation-scheduler-contracts": "pnpm exec tsx ./scripts/check-automation-scheduler-contracts.ts",
    "migrate:github-workflow-labels": "pnpm exec tsx ./scripts/migrate-github-workflow-labels.ts",
    "update:provider-registry-snapshot": "pnpm run check:provider-registry-snapshot -- --write",
    "update:provider-docs": "pnpm run check:provider-docs -- --write",
    "create:provider-module": "pnpm exec tsx ./scripts/create-provider-module.ts",
    "providers:backfill": "pnpm exec tsx ./scripts/canonical-provider-backfill.ts",
    "typecheck": "run-s typecheck:workspace typecheck:convex:gate typecheck:debt",
    "typecheck:web": "pnpm --filter @keppo/web typecheck",
    "typecheck:workspace": "pnpm -r --parallel --if-present run typecheck",
    "typecheck:convex": "pnpm exec tsgo -p convex/tsconfig.json --noEmit",
    "typecheck:convex:gate": "pnpm exec tsgo -p convex/tsconfig.typecheck-gate.json --noEmit",
    "typecheck:debt": "pnpm exec tsx ./scripts/check-type-safety-debt.ts",
    "test": "pnpm -r run test",
    "lint": "run-p lint:provider-checks lint:workspace",
    "lint:provider-checks": "run-p check:provider-guardrails check:sdk-type-compat check:provider-registry-snapshot check:provider-docs",
    "lint:workspace": "pnpm -r --parallel --if-present run lint",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@convex-dev/better-auth": "0.10.13",
    "@keppo/shared": "workspace:*",
    "better-auth": "1.4.9"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260312.1",
    "cel-js": "^0.8.2",
    "convex": "^1.33.0",
    "convex-test": "^0.0.41",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsx": "^4.20.5",
    "turbo": "^2.8.11",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.js": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.jsx": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.ts": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.tsx": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.json": [
      "bash -c 'exit 0'"
    ],
    "*.{css,md,yaml,yml,html}": [
      "bash -c 'exit 0'"
    ]
  },
  "packageManager": "pnpm@9.15.4"
}
