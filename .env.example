# Keppo environment template
# Use as a reference for local overrides or for authoring a committed .env.dev in forks.
# Do not commit real secrets.
# Security-sensitive secrets are fail-closed in non-dev modes (no insecure defaults).

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
# optional (string)
VITE_VAPID_PUBLIC_KEY=replace_with_vapid_public_key
# optional (string)
VITE_POSTHOG_API_KEY=
# optional (string URL)
VITE_POSTHOG_HOST=https://us.i.posthog.com
# optional (string, PostHog personal API key for dashboard sourcemap upload)
POSTHOG_PERSONAL_API_KEY=
# optional (string, PostHog project ID for dashboard sourcemap upload)
POSTHOG_PROJECT_ID=
# optional (string, release metadata for dashboard sourcemap upload)
KEPPO_RELEASE_NAME=keppo-dashboard
# optional (string, release metadata for dashboard sourcemap upload)
KEPPO_RELEASE_VERSION=

# -----------------------------------------------------------------------------
# Convex / Better Auth
# -----------------------------------------------------------------------------
# required (string, >= 32 chars)
BETTER_AUTH_SECRET=replace_with_at_least_32_char_secret
# required (string URL)
KEPPO_URL=http://localhost:3000
# optional (string URL; defaults to KEPPO_URL for local same-site auth)
VITE_KEPPO_URL=http://localhost:3000
# required (boolean; web build injects import.meta.env.VITE_ENABLE_EMAIL_PASSWORD from this value)
ENABLE_EMAIL_PASSWORD=true
# optional (CSV user IDs)
KEPPO_ADMIN_USER_IDS=
# optional (boolean, local dev only)
KEPPO_LOCAL_ADMIN_BYPASS=false
# OAuth provider credentials (required in strict/prod; optional in dev/test/e2e)
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GITHUB_CLIENT_ID=replace_with_github_client_id
GITHUB_CLIENT_SECRET=replace_with_github_client_secret
REDDIT_CLIENT_ID=replace_with_reddit_client_id
REDDIT_CLIENT_SECRET=replace_with_reddit_client_secret

# Optional Mailgun for magic links
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=notifications@example.com
ALLOWED_EMAIL_DOMAINS=

# -----------------------------------------------------------------------------
# API core
# -----------------------------------------------------------------------------
# required (string URL)
CONVEX_URL=http://localhost:3210
# Auto-resolved from .convex/local/default/config.json for local dev.
# Only needed in production/deployed environments.
KEPPO_CONVEX_ADMIN_KEY=replace_with_convex_admin_key
# required (string, >= 32 bytes recommended)
KEPPO_MASTER_KEY=replace_with_32_byte_or_longer_master_key
# required (string)
OPENAI_API_KEY=replace_with_openai_api_key
# optional (boolean-ish; when truthy, require bundled gateway env at API boot)
KEPPO_STRICT_MODE=false
# required in strict/prod (string)
KEPPO_OAUTH_STATE_SECRET=replace_with_oauth_state_secret
# required in strict/prod (string)
KEPPO_CALLBACK_HMAC_SECRET=replace_with_callback_hmac_secret
# optional enum: fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info
# optional (string)
POSTHOG_API_KEY=
# optional (string URL)
POSTHOG_HOST=https://us.i.posthog.com
# optional (string, PagerDuty Events API v2 integration/routing key)
PAGERDUTY_ROUTING_KEY=

# Internal route auth
KEPPO_CRON_SECRET=replace_with_internal_secret
# optional fallback secret alias
KEPPO_QUEUE_SECRET=
# required enum: local|direct|vercel
KEPPO_QUEUE_CLIENT=local

# Optional runtime defaults
KEPPO_ACTION_TTL_MINUTES=60
KEPPO_RUN_INACTIVITY_MINUTES=30
KEPPO_QUEUE_APPROVED_FALLBACK_LIMIT=0
# optional (number, default 10; `/health/deep` marks DLQ down above this threshold)
KEPPO_DLQ_ALERT_THRESHOLD=10
# optional enum: docker|vercel|fly|unikraft
KEPPO_SANDBOX_PROVIDER=docker
# optional Fly Machines automation sandbox config (required when KEPPO_SANDBOX_PROVIDER=fly)
FLY_API_TOKEN=
FLY_API_HOSTNAME=https://api.machines.dev
FLY_AUTOMATION_APP_NAME=
FLY_AUTOMATION_ORG_SLUG=
FLY_AUTOMATION_APP_NETWORK=
FLY_AUTOMATION_IMAGE=registry-1.docker.io/library/node:22-bookworm
FLY_AUTOMATION_MACHINE_REGION=
FLY_AUTOMATION_MACHINE_CPU_KIND=shared
FLY_AUTOMATION_MACHINE_CPUS=1
FLY_AUTOMATION_MACHINE_MEMORY_MB=1024
# optional (bool, default false). Required to acknowledge that Fly does not enforce `mcp_only` egress today.
KEPPO_FLY_ALLOW_UNENFORCED_MCP_ONLY=false
# optional Vercel Sandbox auth (recommended on Vercel)
VERCEL_OIDC_TOKEN=
# optional Vercel Sandbox auth fallback
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# -----------------------------------------------------------------------------
# OAuth bridge providers (configure only what you enable)
# -----------------------------------------------------------------------------
GMAIL_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GMAIL_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GMAIL_API_BASE_URL=https://gmail.googleapis.com/gmail/v1

STRIPE_CLIENT_ID=replace_with_stripe_client_id
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_OAUTH_AUTH_URL=https://connect.stripe.com/oauth/authorize
STRIPE_OAUTH_TOKEN_URL=https://connect.stripe.com/oauth/token
STRIPE_API_BASE_URL=https://api.stripe.com

GITHUB_OAUTH_AUTH_URL=https://github.com/login/oauth/authorize
GITHUB_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_API_BASE_URL=https://api.github.com

REDDIT_OAUTH_AUTH_URL=https://www.reddit.com/api/v1/authorize
REDDIT_OAUTH_TOKEN_URL=https://www.reddit.com/api/v1/access_token
REDDIT_API_BASE_URL=https://oauth.reddit.com

# -----------------------------------------------------------------------------
# Billing / webhook verification
# -----------------------------------------------------------------------------
# required (string)
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
# required (string)
STRIPE_PROVIDER_WEBHOOK_SECRET=replace_with_stripe_provider_webhook_secret
STRIPE_BILLING_WEBHOOK_SECRET=replace_with_stripe_billing_webhook_secret
# legacy fallback for both Stripe webhook secrets
STRIPE_WEBHOOK_SECRET=
# required in strict/prod (string)
GITHUB_WEBHOOK_SECRET=replace_with_github_webhook_secret
STRIPE_HOBBY_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_CREDIT_PRODUCT_ID=
STRIPE_METERED_PRICE_ID=

# -----------------------------------------------------------------------------
# Push notifications
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=replace_with_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_vapid_private_key
VAPID_SUBJECT=mailto:alerts@example.com

# -----------------------------------------------------------------------------
# Optional request-size limits (bytes)
# -----------------------------------------------------------------------------
KEPPO_MAX_BODY_BYTES_OAUTH=65536
KEPPO_MAX_BODY_BYTES_WEBHOOKS=262144
KEPPO_MAX_BODY_BYTES_MCP=262144
KEPPO_MAX_BODY_BYTES_INTERNAL=262144

# -----------------------------------------------------------------------------
# Optional E2E local flags
# -----------------------------------------------------------------------------
KEPPO_E2E_MODE=true
KEPPO_E2E_RUNTIME_MODE=prebuilt
KEPPO_FAKE_EXTERNAL_BASE_URL=http://127.0.0.1:9901
KEPPO_EXTERNAL_FETCH_ALLOWLIST=127.0.0.1:9901
