FROM node:22-alpine
WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY tsconfig.base.json tsconfig.json ./
COPY apps ./apps
COPY cloud ./cloud
COPY convex ./convex
COPY packages ./packages
COPY scripts ./scripts

RUN pnpm install --frozen-lockfile
RUN pnpm run build:workspace-exports
RUN pnpm --filter @keppo/web build

EXPOSE 3000

CMD ["pnpm", "--filter", "@keppo/web", "preview", "--", "--host", "0.0.0.0", "--port", "3000"]
